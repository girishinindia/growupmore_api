<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Welcome to GrowUpMore</title>
</head>
<body style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif; margin: 0; padding: 0; background-color: #F0F9FF;">
    <table cellpadding="0" cellspacing="0" border="0" width="100%" style="background-color: #F0F9FF;">
        <tr>
            <td style="padding: 40px 20px;">
                <table cellpadding="0" cellspacing="0" border="0" width="100%" style="max-width: 600px; margin: 0 auto;">
                    <!-- Header -->
                    <tr>
                        <td style="background: linear-gradient(135deg, #0EA5E9 0%, #0284C7 100%); border-radius: 8px 8px 0 0; padding: 40px 30px; text-align: center;">
                            <h1 style="margin: 0; color: #FFFFFF; font-size: 32px; font-weight: 700; letter-spacing: -0.5px;">GrowUpMore</h1>
                            <p style="margin: 8px 0 0 0; color: #E0F2FE; font-size: 14px; font-weight: 500;">Empower Your Learning Journey</p>
                        </td>
                    </tr>

                    <!-- Body -->
                    <tr>
                        <td style="background-color: #FFFFFF; padding: 40px 30px; border-left: 1px solid #BAE6FD; border-right: 1px solid #BAE6FD;">
                            <h2 style="margin: 0 0 8px 0; color: #1E293B; font-size: 28px; font-weight: 700;">Welcome to GrowUpMore! 🎓</h2>
                            <p style="margin: 0 0 24px 0; color: #64748B; font-size: 13px;">Your account is ready</p>

                            <p style="margin: 0 0 28px 0; color: #475569; font-size: 15px; line-height: 1.6;">
                                Hi {{name}}, we're thrilled to have you on board! GrowUpMore is your dedicated platform for continuous learning and professional growth. Explore hundreds of courses, learn at your own pace, and earn certificates to boost your career.
                            </p>

                            <!-- Features Section -->
                            <table cellpadding="0" cellspacing="0" border="0" width="100%" style="margin: 32px 0;">
                                <tr>
                                    <td style="padding: 16px; background-color: #F0F9FF; border-radius: 8px; border-left: 4px solid #0EA5E9; margin-bottom: 12px;">
                                        <p style="margin: 0 0 4px 0; color: #0EA5E9; font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">Browse Courses</p>
                                        <p style="margin: 0; color: #475569; font-size: 13px; line-height: 1.5;">Discover a wide range of courses tailored to your interests and career goals.</p>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 16px; background-color: #F0F9FF; border-radius: 8px; border-left: 4px solid #0EA5E9; margin-bottom: 12px;">
                                        <p style="margin: 0 0 4px 0; color: #0EA5E9; font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">Learn at Your Pace</p>
                                        <p style="margin: 0; color: #475569; font-size: 13px; line-height: 1.5;">Flexible learning with on-demand video lessons, quizzes, and resources.</p>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 16px; background-color: #F0F9FF; border-radius: 8px; border-left: 4px solid #0EA5E9;">
                                        <p style="margin: 0 0 4px 0; color: #0EA5E9; font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">Get Certified</p>
                                        <p style="margin: 0; color: #475569; font-size: 13px; line-height: 1.5;">Earn recognized certificates upon course completion to showcase your skills.</p>
                                    </td>
                                </tr>
                            </table>

                            <!-- CTA Button -->
                            <table cellpadding="0" cellspacing="0" border="0" width="100%" style="margin: 32px 0;">
                                <tr>
                                    <td style="text-align: center;">
                                        <a href="{{exploreCoursesUrl}}" style="display: inline-block; background: linear-gradient(135deg, #0EA5E9 0%, #0284C7 100%); color: #FFFFFF; padding: 14px 40px; border-radius: 6px; text-decoration: none; font-weight: 600; font-size: 15px; letter-spacing: 0.5px;">Explore Courses</a>
                                    </td>
                                </tr>
                            </table>

                            <p style="margin: 0; color: #64748B; font-size: 13px; line-height: 1.6;">
                                Questions? <a href="{{supportUrl}}" style="color: #0284C7; text-decoration: none; font-weight: 500;">Contact our support team</a>.
                            </p>
                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td style="background-color: #F0F9FF; border-left: 1px solid #BAE6FD; border-right: 1px solid #BAE6FD; border-radius: 0 0 8px 8px; padding: 30px; text-align: center; border-top: 1px solid #BAE6FD;">
                            <p style="margin: 0 0 12px 0; color: #1E293B; font-size: 13px; line-height: 1.6;">
                                <strong>GrowUpMore</strong><br>
                                © {{year}} GrowUpMore. All rights reserved.
                            </p>
                            <p style="margin: 12px 0 0 0; color: #0284C7; font-size: 12px;">
                                <a href="{{supportUrl}}" style="color: #0284C7; text-decoration: none; font-weight: 500;">Contact Support</a>
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>