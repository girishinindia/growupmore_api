<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New User Registration - GrowUpMore Admin</title>
</head>
<body style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif; margin: 0; padding: 0; background-color: #F0F9FF;">
    <table cellpadding="0" cellspacing="0" border="0" width="100%" style="background-color: #F0F9FF;">
        <tr>
            <td style="padding: 40px 20px;">
                <table cellpadding="0" cellspacing="0" border="0" width="100%" style="max-width: 600px; margin: 0 auto;">
                    <!-- Header -->
                    <tr>
                        <td style="background: linear-gradient(135deg, #0EA5E9 0%, #0284C7 100%); border-radius: 8px 8px 0 0; padding: 40px 30px; text-align: center;">
                            <h1 style="margin: 0; color: #FFFFFF; font-size: 32px; font-weight: 700; letter-spacing: -0.5px;">GrowUpMore</h1>
                            <p style="margin: 8px 0 0 0; color: #E0F2FE; font-size: 14px; font-weight: 500;">Admin Notification</p>
                        </td>
                    </tr>

                    <!-- Body -->
                    <tr>
                        <td style="background-color: #FFFFFF; padding: 40px 30px; border-left: 1px solid #BAE6FD; border-right: 1px solid #BAE6FD;">
                            <h2 style="margin: 0 0 8px 0; color: #1E293B; font-size: 22px; font-weight: 700;">New User Registration</h2>
                            <p style="margin: 0 0 24px 0; color: #64748B; font-size: 13px;">A new user has successfully registered</p>

                            <!-- User Details Table -->
                            <table cellpadding="0" cellspacing="0" border="0" width="100%" style="margin: 28px 0; background-color: #F0F9FF; border-radius: 8px; border: 1px solid #BAE6FD;">
                                <tr>
                                    <td style="padding: 16px 20px; border-bottom: 1px solid #BAE6FD; background-color: #E0F2FE;">
                                        <p style="margin: 0; color: #0284C7; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">Full Name</p>
                                    </td>
                                    <td style="padding: 16px 20px; border-bottom: 1px solid #BAE6FD; text-align: right; background-color: #E0F2FE;">
                                        <p style="margin: 0; color: #1E293B; font-size: 14px; font-weight: 500;">{{userName}}</p>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 16px 20px; border-bottom: 1px solid #BAE6FD;">
                                        <p style="margin: 0; color: #0284C7; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">Email Address</p>
                                    </td>
                                    <td style="padding: 16px 20px; border-bottom: 1px solid #BAE6FD; text-align: right;">
                                        <p style="margin: 0; color: #1E293B; font-size: 14px; font-weight: 500;"><a href="mailto:{{userEmail}}" style="color: #0284C7; text-decoration: none;">{{userEmail}}</a></p>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 16px 20px; border-bottom: 1px solid #BAE6FD;">
                                        <p style="margin: 0; color: #0284C7; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">Mobile Number</p>
                                    </td>
                                    <td style="padding: 16px 20px; border-bottom: 1px solid #BAE6FD; text-align: right;">
                                        <p style="margin: 0; color: #1E293B; font-size: 14px; font-weight: 500;">{{userMobile}}</p>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 16px 20px; border-bottom: 1px solid #BAE6FD;">
                                        <p style="margin: 0; color: #0284C7; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">User Role</p>
                                    </td>
                                    <td style="padding: 16px 20px; border-bottom: 1px solid #BAE6FD; text-align: right;">
                                        <p style="margin: 0; color: #1E293B; font-size: 14px; font-weight: 500;">
                                            <span style="background-color: #D1FAE5; color: #047857; padding: 4px 12px; border-radius: 4px; font-size: 12px; font-weight: 600;">{{userRole}}</span>
                                        </p>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 16px 20px;">
                                        <p style="margin: 0; color: #0284C7; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">Registration Time</p>
                                    </td>
                                    <td style="padding: 16px 20px; text-align: right;">
                                        <p style="margin: 0; color: #1E293B; font-size: 14px; font-weight: 500;">{{registrationTime}}</p>
                                    </td>
                                </tr>
                            </table>

                            <!-- Stats -->
                            {{#if totalUsers}}
                            <table cellpadding="0" cellspacing="0" border="0" width="100%" style="margin: 24px 0;">
                                <tr>
                                    <td style="text-align: center; padding: 12px; background-color: #F0F9FF; border-radius: 6px;">
                                        <p style="margin: 0 0 4px 0; color: #0284C7; font-size: 28px; font-weight: 700;">{{totalUsers}}</p>
                                        <p style="margin: 0; color: #64748B; font-size: 13px;">Total Users Registered</p>
                                    </td>
                                </tr>
                            </table>
                            {{/if}}

                            {{#if actionLinks}}
                            <!-- Action Links -->
                            <table cellpadding="0" cellspacing="0" border="0" width="100%" style="margin: 24px 0;">
                                <tr>
                                    <td style="text-align: center; padding: 4px;">
                                        <a href="{{viewUserUrl}}" style="display: inline-block; color: #0284C7; text-decoration: none; font-weight: 500; font-size: 13px; padding: 8px 16px; border: 1px solid #0EA5E9; border-radius: 4px; margin-right: 8px;">View User Profile</a>
                                        <a href="{{manageUsersUrl}}" style="display: inline-block; color: #0284C7; text-decoration: none; font-weight: 500; font-size: 13px; padding: 8px 16px; border: 1px solid #0EA5E9; border-radius: 4px;">Manage Users</a>
                                    </td>
                                </tr>
                            </table>
                            {{/if}}

                            <p style="margin: 0; color: #64748B; font-size: 13px; line-height: 1.6;">
                                This is an automated notification from GrowUpMore Admin System.
                            </p>
                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td style="background-color: #F0F9FF; border-left: 1px solid #BAE6FD; border-right: 1px solid #BAE6FD; border-radius: 0 0 8px 8px; padding: 30px; text-align: center; border-top: 1px solid #BAE6FD;">
                            <p style="margin: 0 0 12px 0; color: #1E293B; font-size: 13px; line-height: 1.6;">
                                <strong>GrowUpMore</strong><br>
                                © {{year}} GrowUpMore. All rights reserved.
                            </p>
                            <p style="margin: 12px 0 0 0; color: #0284C7; font-size: 12px;">
                                <a href="{{supportUrl}}" style="color: #0284C7; text-decoration: none; font-weight: 500;">Admin Support</a>
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>