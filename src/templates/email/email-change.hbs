<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify Email Address - GrowUpMore</title>
</head>
<body style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif; margin: 0; padding: 0; background-color: #F0F9FF;">
    <table cellpadding="0" cellspacing="0" border="0" width="100%" style="background-color: #F0F9FF;">
        <tr>
            <td style="padding: 40px 20px;">
                <table cellpadding="0" cellspacing="0" border="0" width="100%" style="max-width: 600px; margin: 0 auto;">
                    <!-- Header -->
                    <tr>
                        <td style="background: linear-gradient(135deg, #0EA5E9 0%, #0284C7 100%); border-radius: 8px 8px 0 0; padding: 40px 30px; text-align: center;">
                            <h1 style="margin: 0; color: #FFFFFF; font-size: 32px; font-weight: 700; letter-spacing: -0.5px;">GrowUpMore</h1>
                            <p style="margin: 8px 0 0 0; color: #E0F2FE; font-size: 14px; font-weight: 500;">Empower Your Learning Journey</p>
                        </td>
                    </tr>

                    <!-- Body -->
                    <tr>
                        <td style="background-color: #FFFFFF; padding: 40px 30px; border-left: 1px solid #BAE6FD; border-right: 1px solid #BAE6FD;">
                            <p style="margin: 0 0 8px 0; color: #1E293B; font-size: 18px; font-weight: 600;">Hi {{name}},</p>
                            <p style="margin: 0 0 24px 0; color: #64748B; font-size: 13px;">Email address verification</p>

                            <p style="margin: 0 0 28px 0; color: #475569; font-size: 15px; line-height: 1.6;">
                                Someone has requested to change the email address associated with this GrowUpMore account. To confirm this request, please verify this email address using the code below.
                            </p>

                            <!-- OTP Box -->
                            <table cellpadding="0" cellspacing="0" border="0" width="100%" style="margin: 32px 0;">
                                <tr>
                                    <td style="background-color: #F0F9FF; border: 2px solid #0EA5E9; border-radius: 8px; padding: 32px; text-align: center;">
                                        <p style="margin: 0 0 12px 0; color: #0284C7; font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 2px;">Verification Code</p>
                                        <p style="margin: 0; color: #0EA5E9; font-size: 48px; font-weight: 700; letter-spacing: 12px; font-family: 'Courier New', monospace;">{{otp}}</p>
                                    </td>
                                </tr>
                            </table>

                            <p style="margin: 0 0 20px 0; color: #64748B; font-size: 14px; line-height: 1.6; text-align: center;">
                                <strong style="color: #1E293B;">This code expires in {{expiryMinutes}} minutes.</strong>
                            </p>

                            <!-- Email Change Details -->
                            <table cellpadding="0" cellspacing="0" border="0" width="100%" style="margin: 24px 0; background-color: #F0F9FF; border-radius: 8px; border: 1px solid #BAE6FD; padding: 16px;">
                                <tr>
                                    <td>
                                        <p style="margin: 0 0 8px 0; color: #0284C7; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">Current Email</p>
                                        <p style="margin: 0 0 16px 0; color: #1E293B; font-size: 14px;">{{currentEmail}}</p>
                                        <p style="margin: 0 0 8px 0; color: #0284C7; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">New Email</p>
                                        <p style="margin: 0; color: #1E293B; font-size: 14px;">{{newEmail}}</p>
                                    </td>
                                </tr>
                            </table>

                            <!-- Security Warning -->
                            <table cellpadding="0" cellspacing="0" border="0" width="100%" style="margin: 24px 0;">
                                <tr>
                                    <td style="background-color: #FEE2E2; border-left: 4px solid #DC2626; border-radius: 4px; padding: 16px;">
                                        <p style="margin: 0 0 8px 0; color: #7F1D1D; font-size: 13px; font-weight: 600;">
                                            <strong>Didn't request this change?</strong>
                                        </p>
                                        <p style="margin: 0; color: #991B1B; font-size: 13px; line-height: 1.6;">
                                            If you didn't request to change your email address, please ignore this email. Your account is secure.
                                        </p>
                                    </td>
                                </tr>
                            </table>

                            <p style="margin: 0; color: #64748B; font-size: 13px; line-height: 1.6;">
                                Questions? <a href="{{supportUrl}}" style="color: #0284C7; text-decoration: none; font-weight: 500;">Contact our support team</a>.
                            </p>
                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td style="background-color: #F0F9FF; border-left: 1px solid #BAE6FD; border-right: 1px solid #BAE6FD; border-radius: 0 0 8px 8px; padding: 30px; text-align: center; border-top: 1px solid #BAE6FD;">
                            <p style="margin: 0 0 12px 0; color: #1E293B; font-size: 13px; line-height: 1.6;">
                                <strong>GrowUpMore</strong><br>
                                © {{year}} GrowUpMore. All rights reserved.
                            </p>
                            <p style="margin: 12px 0 0 0; color: #0284C7; font-size: 12px;">
                                <a href="{{supportUrl}}" style="color: #0284C7; text-decoration: none; font-weight: 500;">Contact Support</a>
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>